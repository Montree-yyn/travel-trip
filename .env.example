VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Public browser key for Google Maps JavaScript API. Leave blank for the Map fallback UI.
VITE_GOOGLE_MAPS_API_KEY=

# Server-only — Google Cloud Translation key for the /api/translate route.
# Do NOT prefix with VITE_. Set this in the Vercel dashboard, not in .env.
# Leave blank to keep using the mock translation fallback.
GOOGLE_TRANSLATE_API_KEY=

# Server-only — Gemini key for the /api/booking-import route.
# Do NOT prefix with VITE_. Set this in the Vercel dashboard, not in client code.
GEMINI_API_KEY=
